---
import TerminalWindow from './TerminalWindow.astro';
import type { EventItem } from '../data/types';

interface Props {
  events: EventItem[];
  command?: string;
}

const { events, command = '$ ./events --log' } = Astro.props;

const sortedEvents = [...events].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);

function formatEventDate(date: string): string {
  return new Date(`${date}T12:00:00`).toLocaleDateString('es-GT', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<section id="events">
  <TerminalWindow
    windowId="0xEVT_LOG"
    class="border-warning/35 bg-[linear-gradient(135deg,rgba(255,231,161,0.05)_0%,transparent_45%),var(--color-surface)] shadow-[inset_0_0_40px_rgba(255,231,161,0.03)]"
  >
    <p class="mb-6 font-bold text-primary" data-cmd>{command}</p>

    <ol class="relative m-0 list-none space-y-4 p-0">
      {
        sortedEvents.map((event, index) => (
          <li data-event-entry class="relative pl-7">
            <span
              class="absolute left-0 top-5 size-2 rounded-full bg-warning shadow-[0_0_8px_rgba(255,231,161,0.45)]"
              aria-hidden="true"
            />
            {
              index < sortedEvents.length - 1 && (
                <span
                  class="absolute bottom-[-1rem] left-[3px] top-7 w-px bg-[linear-gradient(180deg,rgba(255,231,161,0.35)_0%,rgba(255,231,161,0.15)_50%,transparent_100%)]"
                  aria-hidden="true"
                />
              )
            }

            <article class="group/card flex flex-col gap-2 border border-warning/22 bg-[linear-gradient(90deg,rgba(255,231,161,0.03)_0%,transparent_55%),var(--color-surface-2)] p-4 transition-colors hover:border-warning/45 hover:bg-[linear-gradient(90deg,rgba(255,231,161,0.06)_0%,transparent_60%),var(--color-surface-3)] sm:flex-row sm:items-start sm:justify-between">
              <div class="min-w-0 flex-1">
                <header class="mb-1 text-xs sm:text-sm">
                  <span class="font-bold text-warning">[ {formatEventDate(event.date)} ]</span>
                  <span class="mx-2 text-secondary">-&gt;</span>
                  <span class="font-extrabold tracking-wide text-primary-soft">{event.title}</span>
                </header>

                <p class="text-[11px] leading-relaxed text-copy-soft sm:text-xs">
                  <span class="mr-1 text-secondary">|</span>
                  {event.description}
                </p>
              </div>

              <span class="shrink-0 text-[10px] font-bold tracking-wider text-neutral">{event.id}</span>
            </article>
          </li>
        ))
      }
    </ol>
  </TerminalWindow>
</section>
