---
import TerminalWindow from './TerminalWindow.astro';
import type { ExperienceSection } from '../data/types';

interface Props {
  experience: ExperienceSection;
}

const { experience } = Astro.props;

---

<section id="experience" class="experience-zone">
  <TerminalWindow windowId={experience.windowId}>
    <p class="mb-6 font-bold text-[var(--exp-command)]" data-cmd>{experience.command}</p>

    <ol class="relative m-0 list-none space-y-10 p-0">
      {
        experience.items.map((item, index) => (
          <li data-experience-commit class="experience-commit relative pl-7">
            <span
              class="experience-node absolute left-0 top-1.5 size-2 rounded-full"
              aria-hidden="true"
            />
            {
              index < experience.items.length - 1 && (
                <span class="experience-spine absolute left-[3px] top-4 bottom-[-2.5rem] w-px" aria-hidden="true" />
              )
            }

            <header class="mb-2 text-xs sm:text-sm">
              <span class="font-bold text-[var(--exp-period)]">[ {item.period} ]</span>
              <span class="mx-2 text-[var(--exp-arrow)]">-&gt;</span>
              <span class="font-extrabold tracking-wide text-[var(--exp-title)]">{item.title}</span>
              {item.company && (
                <span class="mt-1 block text-[11px] font-bold text-[var(--exp-highlight)] sm:mt-0 sm:inline sm:pl-2">
                  @ {item.company}
                </span>
              )}
            </header>

            <ul class="mb-3 space-y-1">
              {
                item.highlights.map((line) => (
                  <li class="text-[11px] leading-relaxed text-[var(--exp-highlight)] sm:text-xs">
                    <span class="mr-1 text-[var(--exp-pipe)]">|</span>
                    {line}
                  </li>
                ))
              }
            </ul>

            {
              item.stack.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {
                    item.stack.map((tech) => (
                      <span class="exp-tag">{tech}</span>
                    ))
                  }
                </div>
              )
            }
          </li>
        ))
      }
    </ol>
  </TerminalWindow>
</section>

<style>
  .experience-zone {
    --exp-command: var(--primary);
    --exp-period: var(--warning);
    --exp-arrow: var(--secondary);
    --exp-title: var(--primary-soft);
    --exp-pipe: var(--secondary);
    --exp-highlight: #c8d8bf;
    --exp-tag-text: #a3ad9c;
    --exp-tag-border: rgba(53, 255, 90, 0.14);
    --exp-tag-bg: rgba(15, 22, 15, 0.55);
    --exp-node: var(--primary);
    --exp-spine: rgba(0, 229, 255, 0.35);
    --exp-window-border: rgba(0, 229, 255, 0.4);
    --exp-window-glow: rgba(255, 231, 161, 0.04);
  }

  .experience-zone :global(.experience-window) {
    border-color: var(--exp-window-border);
    background:
      linear-gradient(135deg, rgba(0, 229, 255, 0.05) 0%, transparent 45%),
      linear-gradient(225deg, rgba(255, 231, 161, 0.04) 0%, transparent 40%),
      var(--surface);
    box-shadow: inset 0 0 40px var(--exp-window-glow);
  }

  .exp-tag {
    border: 1px solid var(--exp-tag-border);
    background: var(--exp-tag-bg);
    padding: 0.1rem 0.45rem;
    font-size: 10px;
    line-height: 1.45;
    color: var(--exp-tag-text);
    transition: border-color 0.2s, color 0.2s;
  }

  .experience-commit:hover .exp-tag {
    border-color: rgba(53, 255, 90, 0.24);
    color: #b5c4ad;
  }

  .experience-node {
    background: var(--exp-node);
    box-shadow: 0 0 8px rgba(53, 255, 90, 0.55);
  }

  .experience-spine {
    background: linear-gradient(
      180deg,
      var(--exp-spine) 0%,
      rgba(53, 255, 90, 0.2) 50%,
      transparent 100%
    );
  }
</style>
