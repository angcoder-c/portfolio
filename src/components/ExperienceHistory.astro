---
import TerminalWindow from './TerminalWindow.astro';
import type { ExperienceSection } from '../data/types';

interface Props {
  experience: ExperienceSection;
}

const { experience } = Astro.props;
---

<section id="experience">
  <TerminalWindow
    windowId={experience.windowId}
    >
    <p class="mb-6 font-bold text-primary" data-cmd>{experience.command}</p>

    <ol class="relative m-0 list-none space-y-10 p-0">
      {
        experience.items.map((item, index) => (
          <li data-experience-commit class="group/commit relative pl-7">
            <span
              class="absolute left-0 top-1.5 size-2 rounded-full bg-primary shadow-[0_0_8px_rgba(53,255,90,0.55)]"
              aria-hidden="true"
            />
            {
              index < experience.items.length - 1 && (
                <span
                  class="absolute bottom-[-2.5rem] left-[3px] top-4 w-px bg-[linear-gradient(180deg,rgba(0,229,255,0.35)_0%,rgba(53,255,90,0.2)_50%,transparent_100%)]"
                  aria-hidden="true"
                />
              )
            }

            <header class="mb-2 text-xs sm:text-sm">
              <span class="font-bold text-warning">[ {item.period} ]</span>
              <span class="mx-2 text-secondary">-&gt;</span>
              <span class="font-extrabold tracking-wide text-primary-soft">{item.title}</span>
              {item.company && (
                <span class="mt-1 block text-[11px] font-bold text-copy-soft sm:mt-0 sm:inline sm:pl-2">
                  @ {item.company}
                </span>
              )}
            </header>

            <ul class="mb-3 space-y-1">
              {
                item.highlights.map((line) => (
                  <li class="text-[11px] leading-relaxed text-copy-soft sm:text-xs">
                    <span class="mr-1 text-secondary">|</span>
                    {line}
                  </li>
                ))
              }
            </ul>

            {
              item.stack.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {
                    item.stack.map((tech) => (
                      <span class="border border-primary/14 bg-bg/55 px-[0.45rem] py-[0.1rem] text-[10px] leading-[1.45] text-tag-muted transition-colors group-hover/commit:border-primary/24 group-hover/commit:text-tag-hover">
                        {tech}
                      </span>
                    ))
                  }
                </div>
              )
            }
          </li>
        ))
      }
    </ol>
  </TerminalWindow>
</section>
