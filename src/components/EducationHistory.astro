---
import TerminalWindow from './TerminalWindow.astro';
import type { EducationSection } from '../data/types';

interface Props {
  education: EducationSection;
}

const { education } = Astro.props;

const statusStyles: Record<string, string> = {
  COMPLETED: 'border-success/45 bg-success/10 text-success',
  IN_PROGRESS: 'border-secondary/45 bg-secondary/10 text-secondary',
  CERTIFIED: 'border-primary/45 bg-primary/10 text-primary',
};

function getCertLinkLabel(url: string, index: number): string {
  try {
    const host = new URL(url).hostname.replace(/^www\./, '');
    if (host.includes('credly.com')) {
      return `CREDLY_BADGE_${String(index + 1).padStart(2, '0')}`;
    }
    return `CERT_LINK_${String(index + 1).padStart(2, '0')}`;
  } catch {
    return `CERT_LINK_${String(index + 1).padStart(2, '0')}`;
  }
}
---

<section id="education">
  <TerminalWindow
    windowId={education.windowId ?? '0x7F3_EDU'}
    >
    <p class="mb-6 font-bold text-primary" data-cmd>{education.command}</p>

    <ol class="relative m-0 list-none space-y-4 p-0">
      {
        education.items.map((item, index) => (
          <li data-education-entry class="relative pl-7">
            <span
              class="absolute left-0 top-5 size-2 rounded-full bg-secondary shadow-[0_0_8px_rgba(0,229,255,0.5)]"
              aria-hidden="true"
            />
            {
              index < education.items.length - 1 && (
                <span
                  class="absolute bottom-[-1rem] left-[3px] top-7 w-px bg-[linear-gradient(180deg,rgba(0,229,255,0.3)_0%,rgba(140,255,149,0.18)_50%,transparent_100%)]"
                  aria-hidden="true"
                />
              )
            }

            <article class="group/card flex flex-col gap-3 border border-secondary/22 bg-[linear-gradient(90deg,rgba(0,229,255,0.03)_0%,transparent_55%),var(--color-surface-2)] p-4 transition-colors hover:border-secondary/45 hover:bg-[linear-gradient(90deg,rgba(0,229,255,0.06)_0%,transparent_60%),var(--color-surface-3)] sm:flex-row sm:items-center sm:justify-between">
              <div class="min-w-0 flex-1">
                <header class="mb-1 text-xs sm:text-sm">
                  <span class="font-bold text-warning">[ {item.period} ]</span>
                  <span class="mx-2 text-secondary">-&gt;</span>
                  <span class="font-extrabold tracking-wide text-primary-soft">{item.institution}</span>
                </header>

                <p class="mb-2 text-[11px] leading-relaxed text-copy-soft sm:text-xs">
                  <span class="mr-1 text-secondary">|</span>
                  {item.degree}
                </p>

                {
                  item.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {
                        item.tags.map((tag) => (
                          <span class="border border-secondary/14 bg-bg/55 px-[0.45rem] py-[0.1rem] text-[10px] leading-[1.45] text-tag-muted transition-colors group-hover/card:border-secondary/24 group-hover/card:text-tag-hover">
                            {tag}
                          </span>
                        ))
                      }
                    </div>
                  )
                }

                {
                  item.certificationUrls && item.certificationUrls.length > 0 && (
                    <div class="mt-3 overflow-hidden border-t border-secondary/22 pt-3">
                      <p class="mb-2 text-[10px] font-bold tracking-wider text-warning">
                        >> CERTIFICATION_URLS
                      </p>
                      <ul class="flex flex-col gap-1.5">
                        {
                          item.certificationUrls.map((url, certIndex) => (
                            <li>
                              <a
                                href={url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group/link inline-flex items-center gap-2 text-[11px] text-primary-soft no-underline transition-colors hover:text-primary hover:drop-shadow-[0_0_8px_rgba(53,255,90,0.35)] sm:text-xs"
                              >
                                <span class="text-secondary">|</span>
                                <span class="font-bold">{getCertLinkLabel(url, certIndex)}</span>
                                <span class="truncate text-secondary group-hover/link:text-primary-soft">
                                  → {url}
                                </span>
                              </a>
                            </li>
                          ))
                        }
                      </ul>
                    </div>
                  )
                }
              </div>

              <div class="flex shrink-0 items-center gap-3 sm:flex-col sm:items-end">
                <span class="text-[10px] font-bold tracking-wider text-neutral">{item.id}</span>
                <span class:list={['border px-2 py-0.5 text-[10px] font-bold tracking-wider', statusStyles[item.status] ?? 'border-border text-text-muted']}>
                  {item.status}
                </span>
              </div>
            </article>
          </li>
        ))
      }
    </ol>
  </TerminalWindow>
</section>
