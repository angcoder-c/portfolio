---
import TerminalWindow from './TerminalWindow.astro';
import type { EducationSection } from '../data/types';

interface Props {
  education: EducationSection;
}

const { education } = Astro.props;

const tagToneClasses = ['edu-tag-a', 'edu-tag-b', 'edu-tag-c'] as const;

const statusStyles: Record<string, string> = {
  COMPLETED: 'edu-status-completed',
  IN_PROGRESS: 'edu-status-progress',
  CERTIFIED: 'edu-status-certified',
};

function getCertLinkLabel(url: string, index: number): string {
  try {
    const host = new URL(url).hostname.replace(/^www\./, '');
    if (host.includes('credly.com')) {
      return `CREDLY_BADGE_${String(index + 1).padStart(2, '0')}`;
    }
    return `CERT_LINK_${String(index + 1).padStart(2, '0')}`;
  } catch {
    return `CERT_LINK_${String(index + 1).padStart(2, '0')}`;
  }
}
---

<section id="education" class="education-zone">
  <TerminalWindow windowId={education.windowId ?? '0x7F3_EDU'}>
    <p class="mb-6 font-bold text-[var(--edu-command)]" data-cmd>{education.command}</p>

    <ol class="relative m-0 list-none space-y-4 p-0">
      {
        education.items.map((item, index) => (
          <li data-education-entry class="relative pl-7">
            <span class="education-node absolute left-0 top-5 size-2 rounded-full" aria-hidden="true" />
            {
              index < education.items.length - 1 && (
                <span class="education-spine absolute left-[3px] top-7 bottom-[-1rem] w-px" aria-hidden="true" />
              )
            }

            <article class="education-card flex flex-col gap-3 border p-4 sm:flex-row sm:items-center sm:justify-between">
              <div class="min-w-0 flex-1">
                <header class="mb-1 text-xs sm:text-sm">
                  <span class="font-bold text-[var(--edu-period)]">[ {item.period} ]</span>
                  <span class="mx-2 text-[var(--edu-arrow)]">-&gt;</span>
                  <span class="font-extrabold tracking-wide text-[var(--edu-title)]">{item.institution}</span>
                </header>

                <p class="mb-2 text-[11px] leading-relaxed text-[var(--edu-degree)] sm:text-xs">
                  <span class="mr-1 text-[var(--edu-pipe)]">|</span>
                  {item.degree}
                </p>

                <div class="flex flex-wrap gap-x-3 gap-y-1">
                  {
                    item.tags.map((tag, tagIndex) => (
                      <span class:list={['text-[11px] font-bold sm:text-xs', tagToneClasses[tagIndex % tagToneClasses.length]]}>
                        [ {tag} ]
                      </span>
                    ))
                  }
                </div>

                {
                  item.certificationUrls && item.certificationUrls.length > 0 && (
                    <div class="mt-3 border-t border-[var(--edu-card-border)] pt-3">
                      <p class="mb-2 text-[10px] font-bold tracking-wider text-[var(--edu-cert-heading)]">
                        >> CERTIFICATION_URLS
                      </p>
                      <ul class="flex flex-col gap-1.5">
                        {
                          item.certificationUrls.map((url, certIndex) => (
                            <li>
                              <a
                                href={url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="edu-cert-link inline-flex items-center gap-2 text-[11px] no-underline sm:text-xs"
                              >
                                <span class="text-[var(--edu-pipe)]">|</span>
                                <span class="font-bold">{getCertLinkLabel(url, certIndex)}</span>
                                <span class="edu-cert-url truncate">→ {url}</span>
                              </a>
                            </li>
                          ))
                        }
                      </ul>
                    </div>
                  )
                }
              </div>

              <div class="flex shrink-0 items-center gap-3 sm:flex-col sm:items-end">
                <span class="text-[10px] font-bold tracking-wider text-[var(--edu-id)]">{item.id}</span>
                <span class:list={['border px-2 py-0.5 text-[10px] font-bold tracking-wider', statusStyles[item.status] ?? 'border-border text-text-muted']}>
                  {item.status}
                </span>
              </div>
            </article>
          </li>
        ))
      }
    </ol>
  </TerminalWindow>
</section>

<style>
  .education-zone {
    --edu-command: var(--primary);
    --edu-period: var(--warning);
    --edu-arrow: var(--secondary);
    --edu-title: var(--primary-soft);
    --edu-degree: #c8d8bf;
    --edu-pipe: var(--secondary);
    --edu-id: var(--neutral);
    --edu-node: var(--secondary);
    --edu-spine: rgba(0, 229, 255, 0.3);
    --edu-window-border: rgba(140, 255, 149, 0.35);
    --edu-card-border: rgba(0, 229, 255, 0.22);
    --edu-card-bg: rgba(0, 229, 255, 0.03);
    --edu-cert-heading: var(--warning);
    --edu-cert-url: var(--secondary);
  }

  .education-zone :global(.education-window) {
    border-color: var(--edu-window-border);
    background:
      linear-gradient(135deg, rgba(140, 255, 149, 0.04) 0%, transparent 45%),
      linear-gradient(225deg, rgba(0, 229, 255, 0.04) 0%, transparent 40%),
      var(--surface);
    box-shadow: inset 0 0 40px rgba(140, 255, 149, 0.03);
  }

  .education-card {
    border-color: var(--edu-card-border);
    background: linear-gradient(90deg, var(--edu-card-bg) 0%, transparent 55%), var(--surface-2);
    transition: border-color 0.2s, background 0.2s;
  }

  .education-card:hover {
    border-color: rgba(0, 229, 255, 0.45);
    background: linear-gradient(90deg, rgba(0, 229, 255, 0.06) 0%, transparent 60%), var(--surface-3);
  }

  .education-zone :global(.edu-tag-a) {
    color: var(--secondary);
    text-shadow: 0 0 8px rgba(0, 229, 255, 0.3);
  }

  .education-zone :global(.edu-tag-b) {
    color: var(--success);
    text-shadow: 0 0 8px rgba(140, 255, 149, 0.28);
  }

  .education-zone :global(.edu-tag-c) {
    color: var(--warning);
    text-shadow: 0 0 8px rgba(255, 231, 161, 0.22);
  }

  .education-zone :global(.edu-status-completed) {
    border-color: rgba(140, 255, 149, 0.45);
    background: rgba(140, 255, 149, 0.1);
    color: var(--success);
  }

  .education-zone :global(.edu-status-progress) {
    border-color: rgba(0, 229, 255, 0.45);
    background: rgba(0, 229, 255, 0.1);
    color: var(--secondary);
  }

  .education-zone :global(.edu-status-certified) {
    border-color: rgba(53, 255, 90, 0.45);
    background: rgba(53, 255, 90, 0.1);
    color: var(--primary);
  }

  .education-zone :global(.edu-cert-link) {
    color: var(--primary-soft);
    transition: color 0.2s, text-shadow 0.2s;
  }

  .education-zone :global(.edu-cert-link:hover) {
    color: var(--primary);
    text-shadow: 0 0 8px rgba(53, 255, 90, 0.35);
  }

  .education-zone :global(.edu-cert-url) {
    color: var(--edu-cert-url);
  }

  .education-zone :global(.edu-cert-link:hover .edu-cert-url) {
    color: var(--primary-soft);
  }

  .education-node {
    background: var(--edu-node);
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
  }

  .education-spine {
    background: linear-gradient(
      180deg,
      var(--edu-spine) 0%,
      rgba(140, 255, 149, 0.18) 50%,
      transparent 100%
    );
  }
</style>
