---
import TerminalWindow from './TerminalWindow.astro';
import type { SkillsSection } from '../data/types';

interface Props {
  skills: SkillsSection;
}

const { skills } = Astro.props;
const SKILL_BLOCKS = 20;

const tagToneClasses = ['text-primary', 'text-secondary', 'text-success'] as const;
---

<section id="skills">
  <TerminalWindow
    windowId={skills.windowId ?? '0x424_STAT'}
    >
    <p class="mb-6 font-bold text-primary" data-cmd>{skills.command}</p>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        skills.items.map((skill) => (
          <article
            data-skill-card
            class="group/card border border-primary/20 bg-[linear-gradient(90deg,rgba(53,255,90,0.03)_0%,transparent_60%),var(--color-surface-2)] p-4 transition-colors hover:border-primary/45 hover:bg-[linear-gradient(90deg,rgba(53,255,90,0.06)_0%,transparent_65%),var(--color-surface-3)]"
          >
            <div class="mb-2 flex items-baseline justify-between gap-3">
              <span class="text-sm font-bold text-primary-soft">
                {skill.id} {skill.name}
              </span>
              <span class="text-sm font-bold text-warning">{skill.level}%</span>
            </div>

            <div class="mb-3 flex h-4 gap-0.5" data-skill-bar data-level={skill.level}>
              {
                Array.from({ length: SKILL_BLOCKS }).map(() => (
                  <div class="skill-block h-full w-2 border border-border bg-transparent" />
                ))
              }
            </div>

            <div class="flex flex-wrap gap-x-2 gap-y-1">
              {
                skill.stack.map((tag, tagIndex) => (
                  <span class:list={['text-[11px] font-bold', tagToneClasses[tagIndex % tagToneClasses.length]]}>
                    [{tag}]
                  </span>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </TerminalWindow>
</section>
